# ============================================================
# .ham-autocode/ — allowlist (only track what matters for cross-machine handoff)
#
# Track:  docs/, runtime/, INDEX.md, state/tasks/*.json, state/learning/project-brain.json
# Ignore: 其余全部 (runtime logs, 高频数据, legacy debug 遗留)
# ============================================================

# Default: ignore everything under .ham-autocode/
.ham-autocode/*
.ham-autocode/**/*

# Whitelist what to track
!.ham-autocode/INDEX.md
!.ham-autocode/docs/
!.ham-autocode/docs/**
!.ham-autocode/runtime/
!.ham-autocode/runtime/**
!.ham-autocode/state/
!.ham-autocode/state/tasks/
!.ham-autocode/state/tasks/*.json
!.ham-autocode/state/learning/
!.ham-autocode/state/learning/project-brain.json
!.ham-autocode/state/learning/field-test-log.json

.setting/

# OS
.DS_Store
Thumbs.db

# Node
node_modules/

# TypeScript build output
dist/

# Logs
*.log

# Generated reports
docs/deep-research-report.md
