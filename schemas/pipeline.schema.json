{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ham-autocode Pipeline State v2",
  "description": "Pipeline state file for ham-autocode v2.0. Located at .ham-autocode/pipeline.json in the target project.",
  "type": "object",
  "required": ["schemaVersion", "project", "status", "started_at", "updated_at", "log"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2,
      "description": "Schema version for migration support"
    },
    "project": {
      "type": "string",
      "description": "Project name"
    },
    "status": {
      "type": "string",
      "enum": ["running", "paused", "interrupted", "completed"],
      "description": "running=active, paused=user paused, interrupted=session crashed, completed=all done"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "paused_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "interrupted_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "resumed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "current_task": {
      "type": ["string", "null"],
      "description": "ID of the currently executing task"
    },
    "current_phase": {
      "type": "integer",
      "minimum": 0,
      "maximum": 6,
      "description": "Current pipeline phase (0=init, 1-6=phases)"
    },
    "current_step": {
      "type": ["string", "null"],
      "description": "Human-readable description of current step"
    },
    "last_completed": {
      "type": ["string", "null"],
      "description": "Last completed action (for resume)"
    },
    "next_action": {
      "type": ["string", "null"],
      "description": "What to do next (for resume)"
    },
    "resume_instructions": {
      "type": ["string", "null"],
      "description": "Human-readable instructions for resume"
    },
    "active_agent_teams": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Names of active agent team members"
    },
    "phases": {
      "type": "object",
      "description": "Status of each phase (keys: '1' through '6')",
      "patternProperties": {
        "^[1-6]$": {
          "type": "object",
          "required": ["status", "name"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["pending", "running", "done", "skipped"]
            },
            "name": { "type": "string" },
            "completed_at": { "type": ["string", "null"] }
          }
        }
      }
    },
    "log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["time", "action"],
        "properties": {
          "time": { "type": "string", "format": "date-time" },
          "action": { "type": "string" }
        }
      }
    }
  }
}
